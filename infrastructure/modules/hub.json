          },
          {
            "name": "AllowRDP",
            "properties": {
              "priority": 210,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "3389",
              "sourceAddressPrefix": "[parameters('allowedSourceIpPrefix')]",
              "destinationAddressPrefix": "*"
