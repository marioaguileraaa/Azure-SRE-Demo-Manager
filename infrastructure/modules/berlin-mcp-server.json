{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.40.2.10011",
      "templateHash": "2758760415799505854"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "Location for all MCP server resources"
      }
    },
    "environment": {
      "type": "string",
      "defaultValue": "dev",
      "metadata": {
        "description": "Environment name (e.g., dev, prod) - NOTE: Not used in resource naming as resources are hardcoded to match existing manually deployed Azure resources"
      }
    },
    "containerSubnetId": {
      "type": "string",
      "metadata": {
        "description": "Container subnet ID from hub VNet"
      }
    },
    "berlinApiUrl": {
      "type": "string",
      "metadata": {
        "description": "URL of the Berlin Parking API to monitor"
      }
    },
    "containerImage": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Container image for the MCP server"
      }
    },
    "containerRegistry": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Container registry server (leave empty for public registries)"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Tags to apply to resources"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "law-berlin-mcp",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "appi-parking-berlin-mcp",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', 'law-berlin-mcp')]",
        "IngestionMode": "LogAnalytics",
        "publicNetworkAccessForIngestion": "Enabled",
        "publicNetworkAccessForQuery": "Enabled"
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', 'law-berlin-mcp')]"
      ]
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2023-05-01",
      "name": "cae-berlin-mcp",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', 'law-berlin-mcp'), '2022-10-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', 'law-berlin-mcp'), '2022-10-01').primarySharedKey]"
          }
        },
        "vnetConfiguration": {
          "infrastructureSubnetId": "[parameters('containerSubnetId')]"
        },
        "workloadProfiles": [
          {
            "name": "Consumption",
            "workloadProfileType": "Consumption"
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', 'law-berlin-mcp')]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "ca-berlin-mcp",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', 'cae-berlin-mcp')]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 8080,
            "transport": "auto",
            "allowInsecure": false
          },
          "registries": "[if(empty(parameters('containerRegistry')), createArray(), createArray(createObject('server', parameters('containerRegistry'), 'identity', 'system')))]"
        },
        "template": {
          "containers": [
            {
              "name": "berlin-mcp-server",
              "image": "[if(empty(parameters('containerImage')), 'mcr.microsoft.com/azuredocs/containerapps-helloworld:latest', parameters('containerImage'))]",
              "resources": {
                "cpu": "[json('0.25')]",
                "memory": "0.5Gi"
              },
              "env": [
                {
                  "name": "BERLIN_API_URL",
                  "value": "[parameters('berlinApiUrl')]"
                },
                {
                  "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
                  "value": "[reference(resourceId('Microsoft.Insights/components', 'appi-parking-berlin-mcp'), '2020-02-02').ConnectionString]"
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 3
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', 'appi-parking-berlin-mcp')]",
        "[resourceId('Microsoft.App/managedEnvironments', 'cae-berlin-mcp')]"
      ]
    }
  ],
  "outputs": {
    "containerAppName": {
      "type": "string",
      "value": "ca-berlin-mcp"
    },
    "containerAppFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', 'ca-berlin-mcp'), '2023-05-01').configuration.ingress.fqdn]"
    },
    "mcpServerUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', 'ca-berlin-mcp'), '2023-05-01').configuration.ingress.fqdn)]"
    },
    "containerAppEnvironmentName": {
      "type": "string",
      "value": "cae-berlin-mcp"
    },
    "containerAppEnvironmentId": {
      "type": "string",
      "value": "[resourceId('Microsoft.App/managedEnvironments', 'cae-berlin-mcp')]"
    },
    "appInsightsName": {
      "type": "string",
      "value": "appi-parking-berlin-mcp"
    },
    "logAnalyticsWorkspaceName": {
      "type": "string",
      "value": "law-berlin-mcp"
    },
    "containerAppPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', 'ca-berlin-mcp'), '2023-05-01', 'full').identity.principalId]"
    }
  }
}