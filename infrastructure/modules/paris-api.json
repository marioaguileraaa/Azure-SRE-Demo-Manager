{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.40.2.10011",
      "templateHash": "4922745226047476224"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "Location for all Paris API resources"
      }
    },
    "vmSubnetId": {
      "type": "string",
      "metadata": {
        "description": "VM subnet ID from hub VNet"
      }
    },
    "adminUsername": {
      "type": "string",
      "metadata": {
        "description": "Admin username for the VM"
      }
    },
    "adminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Admin password for the VM"
      }
    },
    "createPublicIp": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Create public IP for the VM"
      }
    },
    "deployVM": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Deploy VM resources (set to false if VM already exists to avoid disk update conflicts)"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Tags to apply to resources"
      }
    }
  },
  "resources": [
    {
      "condition": "[parameters('createPublicIp')]",
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-05-01",
      "name": "pip-paris-vm",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static",
        "dnsSettings": {
          "domainNameLabel": "[format('paris-parking-{0}', uniqueString(resourceGroup().id))]"
        }
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2023-05-01",
      "name": "nic-paris-vm",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "subnet": {
                "id": "[parameters('vmSubnetId')]"
              },
              "privateIPAllocationMethod": "Dynamic",
              "publicIPAddress": "[if(parameters('createPublicIp'), createObject('id', resourceId('Microsoft.Network/publicIPAddresses', 'pip-paris-vm')), null())]"
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/publicIPAddresses', 'pip-paris-vm')]"
      ]
    },
    {
      "condition": "[parameters('deployVM')]",
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2023-03-01",
      "name": "vm-paris-api",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "hardwareProfile": {
          "vmSize": "Standard_B2s"
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "Canonical",
            "offer": "0001-com-ubuntu-server-jammy",
            "sku": "22_04-lts-gen2",
            "version": "latest"
          },
          "osDisk": {
            "name": "osdisk-paris-vm",
            "createOption": "FromImage",
            "managedDisk": {
              "storageAccountType": "StandardSSD_LRS"
            },
            "diskSizeGB": 30
          }
        },
        "osProfile": {
          "computerName": "paris-api",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPassword')]",
          "linuxConfiguration": {
            "disablePasswordAuthentication": false,
            "provisionVMAgent": true,
            "patchSettings": {
              "patchMode": "AutomaticByPlatform"
            }
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', 'nic-paris-vm')]"
            }
          ]
        },
        "diagnosticsProfile": {
          "bootDiagnostics": {
            "enabled": true
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', 'nic-paris-vm')]"
      ]
    },
    {
      "condition": "[parameters('deployVM')]",
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2023-03-01",
      "name": "[format('{0}/{1}', 'vm-paris-api', 'AzureMonitorLinuxAgent')]",
      "location": "[parameters('location')]",
      "properties": {
        "publisher": "Microsoft.Azure.Monitor",
        "type": "AzureMonitorLinuxAgent",
        "typeHandlerVersion": "1.0",
        "autoUpgradeMinorVersion": true,
        "enableAutomaticUpgrade": true
      },
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', 'vm-paris-api')]"
      ]
    },
    {
      "condition": "[parameters('deployVM')]",
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2023-03-01",
      "name": "[format('{0}/{1}', 'vm-paris-api', 'CustomScriptExtension')]",
      "location": "[parameters('location')]",
      "properties": {
        "publisher": "Microsoft.Azure.Extensions",
        "type": "CustomScript",
        "typeHandlerVersion": "2.1",
        "autoUpgradeMinorVersion": true,
        "settings": {
          "script": "[base64('#!/bin/bash\nset -e\n\n# Update package lists\napt-get update\n\n# Install required packages\napt-get install -y ca-certificates curl gnupg rsyslog\n\n# Setup NodeSource repository for Node.js 18.x\nmkdir -p /etc/apt/keyrings\ncurl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor --batch --yes -o /etc/apt/keyrings/nodesource.gpg 2>/dev/null || true\necho \"deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_18.x nodistro main\" | tee /etc/apt/sources.list.d/nodesource.list\n\n# Install Node.js\napt-get update\napt-get install -y nodejs\n\n# Verify installation\nnode --version\nnpm --version\n')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines/extensions', 'vm-paris-api', 'AzureMonitorLinuxAgent')]",
        "[resourceId('Microsoft.Compute/virtualMachines', 'vm-paris-api')]"
      ]
    }
  ],
  "outputs": {
    "vmName": {
      "type": "string",
      "value": "[if(parameters('deployVM'), 'vm-paris-api', '')]"
    },
    "vmId": {
      "type": "string",
      "value": "[if(parameters('deployVM'), resourceId('Microsoft.Compute/virtualMachines', 'vm-paris-api'), '')]"
    },
    "vmPrincipalId": {
      "type": "string",
      "value": "[if(parameters('deployVM'), reference(resourceId('Microsoft.Compute/virtualMachines', 'vm-paris-api'), '2023-03-01', 'full').identity.principalId, '')]"
    },
    "privateIpAddress": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/networkInterfaces', 'nic-paris-vm'), '2023-05-01').ipConfigurations[0].properties.privateIPAddress]"
    },
    "publicIpAddress": {
      "type": "string",
      "value": "[if(and(parameters('deployVM'), parameters('createPublicIp')), reference(resourceId('Microsoft.Network/publicIPAddresses', 'pip-paris-vm'), '2023-05-01').ipAddress, '')]"
    },
    "fqdn": {
      "type": "string",
      "value": "[if(and(parameters('deployVM'), parameters('createPublicIp')), reference(resourceId('Microsoft.Network/publicIPAddresses', 'pip-paris-vm'), '2023-05-01').dnsSettings.fqdn, '')]"
    },
    "apiUrl": {
      "type": "string",
      "value": "[if(and(parameters('deployVM'), parameters('createPublicIp')), format('http://{0}:3003', reference(resourceId('Microsoft.Network/publicIPAddresses', 'pip-paris-vm'), '2023-05-01').dnsSettings.fqdn), format('http://{0}:3003', reference(resourceId('Microsoft.Network/networkInterfaces', 'nic-paris-vm'), '2023-05-01').ipConfigurations[0].properties.privateIPAddress))]"
    }
  }
}