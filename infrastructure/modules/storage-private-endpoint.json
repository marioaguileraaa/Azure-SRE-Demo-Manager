      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Tags to apply to resources"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2020-06-01",
      "name": "[format('privatelink.blob.{0}', environment().suffixes.storage)]",
      "location": "global",
      "tags": "[parameters('tags')]"
    },
    {
